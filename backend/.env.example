# ── SERVER ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://www.shemsolar.co.ke

# ── POSTGRESQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shem_solar
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false               # set to true on Railway/Render/Supabase

# ── M-PESA DARAJA API ────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_SHORTCODE=174379                   # your Paybill or Till number
MPESA_CALLBACK_URL=https://api.shemsolar.co.ke/api/v1/mpesa/callback
MPESA_ENV=sandbox                        # sandbox | production

# ── AFRICA'S TALKING SMS ─────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=shemsolar                    # sandbox username: "sandbox"
AT_SENDER_ID=ShemSolar                   # max 11 chars, registered with AT

# ── REDIS (for BullMQ job queue) ─────────────────────
REDIS_URL=redis://localhost:6379

# ── SECURITY ─────────────────────────────────────────
ADMIN_SECRET=your_very_long_random_admin_secret_key
PORTAL_TOKEN=your_customer_portal_readonly_token
